###############################################################################
# ZOLVE Worker — variáveis de ambiente
# Copie para .env e ajuste antes de rodar: make infra && npm run start:dev
###############################################################################

NODE_ENV=development
PORT=3002

# ─── Docker Compose (compartilhado com a API) ────────────────────────────
# Use o mesmo valor do projeto da API para compartilhar os serviços.
COMPOSE_PROJECT_NAME=domestic

# ─── PostgreSQL ───────────────────────────────────────────────────────────
DATABASE_POSTGRES_HOST=localhost
DATABASE_POSTGRES_PORT=5432
DATABASE_POSTGRES_NAME=zolve
DATABASE_POSTGRES_USER=zolve
DATABASE_POSTGRES_PASSWORD=zolve123
DATABASE_POSTGRES_SYNCHRONIZE=false
DATABASE_POSTGRES_LOGGING=true
DATABASE_POSTGRES_TIMEZONE=UTC

# ─── MongoDB ──────────────────────────────────────────────────────────────
# MONGO_URI tem precedência — use-a em dev (sem auth) e prod (com auth)
MONGO_URI=mongodb://localhost:27017/zolve
DATABASE_MONGO_HOST=localhost
DATABASE_MONGO_PORT=27017
DATABASE_MONGO_NAME=zolve
DATABASE_MONGO_LOGGING=true
DATABASE_MONGO_SYNCHRONIZE=false

# ─── RabbitMQ ─────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://zolve:zolve123@localhost:5672
RABBITMQ_EXCHANGE=zolve.events
RABBITMQ_PREFETCH=10

# ─── Worker ───────────────────────────────────────────────────────────────
WORKER_MAX_RETRIES=3
WORKER_RETRY_DELAY_MS=60000
WORKER_DLQ_ENABLED=true

# ─── SMTP ─────────────────────────────────────────────────────────────────
# Em dev: aponte para Mailpit (make infra sobe na porta 1025)
# Em prod: use SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_USER=apikey
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=ZOLVE
SMTP_FROM_EMAIL=noreply@zolve.local

# ─── Firebase FCM — opcional (deixe em branco para desabilitar push) ──────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
